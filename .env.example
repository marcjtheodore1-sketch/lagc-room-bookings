# Email Configuration (optional - without this, emails are logged to console only)

# SMTP Server settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your email credentials
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# The "from" address that appears in emails
SMTP_FROM=bookings@yourcompany.com

# Set to true to enable email sending
ENABLE_EMAIL=false

# For Gmail users:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Generate an App Password (requires 2FA enabled)
# 3. Use that password as SMTP_PASSWORD (not your regular password)

# Admin Password (default is 'Moonlight' if not set)
# ADMIN_PASSWORD=YourSecurePasswordHere
